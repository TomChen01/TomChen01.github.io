---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Hongyi Chen (Tom Chen) | Machine Learning & Data Science"
	description="Hongyi Tom Chen is a CUHK-Shenzhen data science undergraduate and machine learning algorithm intern at Shanshu Technology in Shanghai."
>
	<aside id="status-card" class="fixed top-[4.75rem] sm:top-[5.5rem] right-4 sm:right-6 lg:right-10 z-40 w-[calc(100%_-_2rem)] sm:w-[min(28rem,calc(100%_-_3rem))] rounded-2xl border border-blue-200 bg-white/95 p-4 sm:p-5 shadow-xl shadow-gray-900/10 backdrop-blur" aria-label="Current status">
		<button id="dismiss-status" class="absolute right-3 top-3 rounded-full p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-700" aria-label="Dismiss current status">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
		</button>
		<div class="flex items-start gap-3 pr-8">
			<span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-emerald-500 ring-4 ring-emerald-100"></span>
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.16em] text-blue-700">Now · July 2026</p>
				<p class="mt-1 text-sm sm:text-base leading-relaxed text-gray-700">
					I joined <a href="https://www.shanshu.ai/about" target="_blank" rel="noopener noreferrer" class="font-semibold text-blue-700 underline decoration-blue-300 underline-offset-2 hover:text-blue-900">Shanshu Technology (杉数科技 · Shanghai)</a> as an <strong>Algorithm Intern</strong>, focusing on machine learning.
				</p>
			</div>
		</div>
	</aside>

	<section class="min-h-[62vh] flex flex-col-reverse md:flex-row items-center md:items-start justify-between gap-10 md:gap-12 py-8 sm:py-12 md:py-20">
		<div class="min-w-0 flex-[3] space-y-6">
			<h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 leading-tight">
				Hi, I'm Hongyi (Tom) Chen :)
			</h1>
			<p class="text-base md:text-lg text-gray-700 leading-relaxed max-w-2xl font-normal">
				I am a Data Science undergraduate at <strong>CUHK-Shenzhen</strong> and completed a visiting program in Computer Science at <strong>UC Berkeley</strong> in Fall 2025.
				My interests span <strong>medical AI</strong>, <strong>large language model theory</strong>, quantitative finance, and data analysis, with a focus on using data-driven methods to build and evaluate reliable models.
			</p>
			
			<div class="flex flex-wrap gap-3 sm:gap-4 pt-2">
				<a href="https://linkedin.com/in/tomchen17" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 sm:px-6 py-2 bg-white border border-gray-900 text-gray-900 font-medium rounded-lg hover:bg-gray-100 transition-colors">
					LinkedIn 
                    <svg class="w-4 h-4 text-gray-900" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 21.227.792 22 1.771 22h20.451C23.2 22 24 21.227 24 20.542V1.729C24 .774 23.2 0 22.225 0z"/></svg>
				</a>
				<a href="https://github.com/TomChen01" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 sm:px-6 py-2 bg-white border border-gray-900 text-gray-900 font-medium rounded-lg hover:bg-gray-100 transition-colors">
					Github
                    <svg class="w-4 h-4 text-gray-900" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
				</a>
				<a href="mailto:tomchen0417@gmail.com" class="inline-flex items-center gap-2 px-4 sm:px-6 py-2 bg-white border border-gray-900 text-gray-900 font-medium rounded-lg hover:bg-gray-100 transition-colors">
					Email
					<svg class="w-4 h-4 text-gray-900" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" /><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" /></svg>
				</a>
			</div>
		</div>
		
		<div class="w-full md:w-auto flex-1 md:flex-none flex justify-center md:justify-end">
			<div class="relative w-52 h-56 sm:w-60 sm:h-64 md:w-[227px] md:h-[249px] overflow-hidden rounded-2xl shadow-sm">
				<!-- Placeholder Image -->
				<img 
					src="/me1.jpg" 
					alt="Hongyi (Tom) Chen" 
					class="w-full h-full object-cover"
				/>
			</div>
		</div>
	</section>
	<script>
		const card = document.querySelector<HTMLElement>('#status-card');
		const dismissButton = document.querySelector<HTMLButtonElement>('#dismiss-status');
		if (sessionStorage.getItem('status-card-dismissed-v2') === 'true') card?.remove();
		dismissButton?.addEventListener('click', () => {
			sessionStorage.setItem('status-card-dismissed-v2', 'true');
			card?.remove();
		});
	</script>
</BaseLayout>
