---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  {
    category: "Programming & Web",
    items: ["Python", "R", "SQL", "Java", "C", "JavaScript", "HTML/CSS", "LaTeX", "Git"]
  },
  {
    category: "Machine Learning & Data",
    items: ["PyTorch", "Scikit-learn", "Transformers", "Pandas", "NumPy", "Tableau"]
  }
];

const experience = [
  {
    category: "Research",
    items: [
      {
        role: "Undergraduate Researcher: EHRFormer",
        organization: "Cardiac Sudden Death Prediction (Advisor: Prof. Joshua Zhou)",
        date: "Apr 2026 – Present",
        description: "Developing a standardized multi-center electronic health record pipeline and fine-tuning EHRFormer with LoRA for cardiac sudden death prediction and downstream clinical evaluation."
      },
      {
        role: "Undergraduate Researcher: SkinGPT-X",
        organization: "Medical Foundation Model Evaluation (Advisor: Prof. Joshua Zhou)",
        date: "Dec 2025 – Present",
        description: "Contributing to an evaluation framework for medical foundation models, including Qwen3, MedGemma, and HuLuMed, with a focus on diagnostic accuracy, complex-case reasoning, and structured error analysis."
      },
      {
        role: "Undergraduate Researcher: Model Editing",
        organization: "Course Project (Advisor: Prof. Anant Sahai, UC Berkeley)",
        date: "Nov 2025 – Dec 2025",
        description: "Designed experiments on <strong>Pythia-6.9B</strong> using causal tracing and collision analysis, showing that neuron-level FiNE editing causes more collateral damage than layer-level ROME editing when targeting polysemantic neurons."
      }
    ]
  },
  {
    category: "Internships",
    items: [
      {
        role: "Fintech Algorithm Intern",
        organization: "China Merchants Bank, Xiamen",
        date: "Jul 2025 – Aug 2025",
        description: "Optimized a text classification model for anti-fraud detection, increasing <strong>AUC by 12%</strong> while reducing false positives, and developed token-level feature attribution for prediction analysis and review."
      },
      {
        role: "Data Analysis Intern",
        organization: "DigitSuper Technology",
        date: "Apr 2025 – Jun 2025",
        description: "Analyzed advertising data with Python and SQL to identify conversion drivers and improve a core product's <strong>BSR by 20%</strong>; designed A/B tests for real-time bidding strategies that increased <strong>ROAS by 10%</strong>."
      }
    ]
  }
];
---

<BaseLayout
  title="Hongyi (Tom) Chen | About"
  description="Learn about Hongyi (Tom) Chen's education, medical AI and LLM research, quantitative projects, data analysis experience, and technical skills."
>
  <article class="max-w-3xl mx-auto space-y-12">
    <!-- Header -->
    <header class="flex flex-col-reverse md:flex-row items-start justify-between gap-8 md:gap-12">
      <div class="flex-[3] space-y-4">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 leading-tight">
          Hi, I'm Hongyi (Tom) Chen
        </h1>
        <p class="text-lg text-gray-600 leading-relaxed">
          I am a Data Science undergraduate at <strong>CUHK-Shenzhen</strong> and completed a visiting program in Computer Science at <strong>UC Berkeley</strong> in Fall 2025.
          My work spans medical AI, large language model research, quantitative finance, and data analysis.
        </p>
      </div>
      
      <div class="flex-1 md:flex-none flex justify-center md:justify-end">
        <div class="relative w-32 h-32 md:w-40 md:h-40 overflow-hidden rounded-full border-2 border-gray-100 shadow-sm shrink-0">
          <img 
            src="/me1.jpg" 
            alt="Hongyi (Tom) Chen" 
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </header>
    
    <!-- CV Download -->
    <div class="flex flex-col sm:flex-row sm:items-center gap-4 p-4 bg-gray-100 rounded-lg border border-gray-200">
      <p class="text-gray-600 flex-grow">
        CVs updated Jun 2026
      </p>
      <div class="flex flex-wrap gap-2">
        <a href="/resume.pdf" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-gray-900 text-sm font-medium rounded-md hover:bg-gray-50 transition-colors shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          English
        </a>
        <a href="/resume-zh.pdf" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-gray-900 text-sm font-medium rounded-md hover:bg-gray-50 transition-colors shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          中文
        </a>
      </div>
    </div>

    <!-- Education -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
        Education
      </h2>
      <div class="relative space-y-8 ml-3 pl-0.5">
        <div class="absolute top-2 bottom-0 left-0 w-0.5 bg-gray-200"></div>
        <div class="relative pl-8">
          <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-white border-2 border-gray-900"></div>
          <h3 class="text-lg font-semibold text-gray-900">The Chinese University of Hong Kong, Shenzhen</h3>
          <p class="text-gray-600">B.S. in Data Science</p>
          <p class="text-sm text-gray-500 mt-1">Sep 2023 – Present · GPA: 3.5/4.0 · Top 25% in Major</p>
          <p class="text-sm text-gray-600 mt-2 leading-relaxed">
            Coursework: Machine Learning, Optimization, Stochastic Processes, Discrete Mathematics, Ordinary Differential Equations, Probability and Statistics, Linear Algebra, and Data Structures.
          </p>
          <p class="text-sm text-gray-600 mt-2">
            Honors: Dean's List (2023–2024); Zhixing Social Practice Second Prize.
          </p>
        </div>
        <div class="relative pl-8">
          <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-gray-200 border-2 border-gray-300"></div>
          <h3 class="text-lg font-semibold text-gray-900">University of California, Berkeley</h3>
          <p class="text-gray-600">Visiting Student, Computer Science</p>
          <p class="text-sm text-gray-500 mt-1">Aug 2025 – Dec 2025</p>
          <p class="text-sm text-gray-600 mt-2">
            Coursework: Introduction to Artificial Intelligence, Machine Structures, and Designing, Visualizing and Understanding Deep Neural Networks.
          </p>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        Experience
      </h2>
      
      <div class="space-y-10">
        {experience.map((group) => (
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-4 uppercase tracking-wider text-sm border-b pb-2">{group.category}</h3>
            <div class="space-y-6">
              {group.items.map((item) => (
                <div class="group">
                  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-1">
                    <h4 class="font-bold text-gray-900 text-lg">{item.role}</h4>
                    <span class="text-sm text-gray-500 whitespace-nowrap">{item.date}</span>
                  </div>
                  <p class="text-gray-500 italic mb-2 text-sm">{item.organization}</p>
                  <p class="text-gray-600 text-sm leading-relaxed" set:html={item.description}></p>
                </div>
              ))}
            </div>
          </div>
        ))}

        <!-- Projects Link -->
        <div>
           <h3 class="text-lg font-bold text-gray-900 mb-4 uppercase tracking-wider text-sm border-b pb-2">Selected Projects</h3>
           <p class="text-gray-600 mb-4">My selected projects cover model editing, quantitative forecasting, and on-device AI agents.</p>
           <a href="/projects" class="inline-flex items-center text-blue-600 font-medium hover:text-blue-800 transition-colors">
             View All Projects 
             <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
           </a>
        </div>
      </div>
    </section>

    <!-- Leadership & Extracurricular -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        Leadership & Extracurricular
      </h2>
      <div class="space-y-6">
        <div>
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-1">
            <h3 class="font-bold text-gray-900 text-lg">Project Lead, Zhixing Social Practice Program</h3>
            <span class="text-sm text-gray-500 whitespace-nowrap">Jun 2024 – Oct 2024</span>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed">
            Led survey data processing and feature engineering with Python and Pandas, applied K-Means clustering to identify four core user profiles, and delivered findings adopted by CUHK-Shenzhen for student engagement planning.
          </p>
        </div>
        <div>
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-1">
            <h3 class="font-bold text-gray-900 text-lg">Co-Lead, Rural Revitalization Program</h3>
            <span class="text-sm text-gray-500 whitespace-nowrap">Aug 2024</span>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed">
            Led stakeholder interviews and primary data collection, structured qualitative findings through thematic analysis, and co-authored a report adopted by the local government and featured by local media.
          </p>
        </div>
      </div>
    </section>

    <!-- Languages -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Languages</h2>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm font-medium border border-gray-200">Mandarin (Native)</span>
        <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm font-medium border border-gray-200">English (TOEFL 109)</span>
      </div>
    </section>

    <!-- Tech Stack -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
        Technical Skills
      </h2>
      <div class="space-y-6">
        {skills.map((group) => (
          <div>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">{group.category}</h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map((skill) => (
                <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm font-medium border border-gray-200">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Hobbies -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        Hobbies
      </h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 text-gray-600">
        <li class="flex items-center gap-3">
          <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
          <span>Soccer</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="w-2 h-2 bg-indigo-500 rounded-full"></span>
          <span>Marathon & Hiking</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
          <span>Novels & Films</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="w-2 h-2 bg-pink-500 rounded-full"></span>
          <span>Traveling</span>
        </li>
      </ul>
    </section>
  </article>
</BaseLayout>
